# Backend Configuration Environment Variables

# Server Mode ("true" for mock in-memory database & simulation, "false" for real MongoDB & MQTT)
MOCK_MODE=false

# MongoDB Connection (only used when MOCK_MODE=false)
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=smart_waste_db

# MQTT Broker (only used when MOCK_MODE=false)
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# SMS/Email notification webhook url (e.g. Twilio hook or mock bin)
TWILIO_WEBHOOK_URL=http://httpbin.org/post

# CORS Allowed Origins (comma-separated, default is "*" which disables credentials support)
ALLOWED_ORIGINS=*
