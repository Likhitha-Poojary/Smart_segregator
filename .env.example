# Smart Waste Management Deployment Environment Variables

# Backend settings
MOCK_MODE=false
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=smart_waste_db
MQTT_BROKER=mosquitto
MQTT_PORT=1883
TWILIO_WEBHOOK_URL=http://httpbin.org/post
ALLOWED_ORIGINS=*

